# Yjs server URL - change this to your Yjs server URL in production
# For local development: localhost:1999
# For production: yjs.kanwas.ai or your custom domain
VITE_YJS_SERVER_URL=localhost:1999

# Backend API URL - change this to your backend server URL in production
# For local development: http://localhost:3333
# For production: https://api.your-domain.com
VITE_API_URL=http://localhost:3333

# Auth token storage key (optional override)
VITE_AUTH_TOKEN_KEY=auth_token

# Optional local-dev convenience: automatically log into /auth/default when no token exists.
# Requires backend DEFAULT_USER_LOGIN_ENABLED=true. Keep false for multi-user auth testing.
VITE_DEFAULT_AUTH_ENABLED=false
